<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="12dp"
    android:gravity="center_vertical">

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:singleLine="true"
        android:text="MeRS Remote"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <ViewFlipper
        android:id="@+id/widget_carousel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:autoStart="false">

        <!-- Item 1 -->
        <LinearLayout
            android:id="@+id/item1_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView
                android:id="@+id/item1_menu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:singleLine="true"
                android:textColor="#38bdf8"
                android:textSize="12sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/item1_detail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:singleLine="true"
                android:textColor="#94a3b8"
                android:textSize="10sp"
                android:layout_marginTop="1dp" />
        </LinearLayout>

        <!-- Item 2 -->
        <LinearLayout
            android:id="@+id/item2_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView
                android:id="@+id/item2_menu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:singleLine="true"
                android:textColor="#38bdf8"
                android:textSize="12sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/item2_detail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:singleLine="true"
                android:textColor="#94a3b8"
                android:textSize="10sp"
                android:layout_marginTop="1dp" />
        </LinearLayout>
    </ViewFlipper>
</LinearLayout>
